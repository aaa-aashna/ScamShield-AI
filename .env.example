# Frontend
VITE_API_URL=http://localhost:8000/api/v1

# Backend
BACKEND_SECRET_KEY=your-secret-key-change-this-in-production
BACKEND_DEBUG=true
BACKEND_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","http://127.0.0.1:5173"]

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/scamshield
DATABASE_TEST_URL=postgresql://postgres:postgres@localhost:5432/scamshield_test

# Redis
REDIS_URL=redis://localhost:6379

# Authentication
JWT_EXPIRATION_HOURS=24
JWT_REFRESH_EXPIRATION_DAYS=7
JWT_ALGORITHM=HS256

# Email (for notifications and password reset)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@scamshield-ai.com
SMTP_FROM_NAME=ScamShield AI

# OAuth2 (Optional)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# API Keys (External Services)
VIRUSTOTAL_API_KEY=your-virustotal-api-key
URLSCAN_API_KEY=your-urlscan-api-key

# AI/ML Configuration
MODEL_CACHE_DIR=./models
MAX_UPLOAD_SIZE_MB=10
BATCH_SIZE=32

# Security
ALLOWED_HOSTS=localhost,127.0.0.1
SECURE_COOKIES=false
SECURE_HTTPS_ONLY=false

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/scamshield.log

# Sentry (Error Tracking - Optional)
SENTRY_DSN=

# Environment
ENVIRONMENT=development
